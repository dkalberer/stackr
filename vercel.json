{
  "buildCommand": "pnpm --filter frontend build",
  "outputDirectory": "apps/frontend/dist",
  "installCommand": "pnpm install",
  "framework": "vite",
  "ignoreCommand": "git diff ${VERCEL_GIT_PREVIOUS_SHA:-HEAD^} HEAD --quiet -- apps/frontend vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://stackr.onrender.com/api/:path*"
    }
  ]
}
